# Esperion Agency Web - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION=30d

# ===========================================
# SurrealDB Configuration
# ===========================================
SURREAL_USER=root
SURREAL_PASS=root
DATABASE_URL=ws://localhost:8000

# ===========================================
# reCAPTCHA v3 Configuration
# ===========================================
NUXT_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_MIN_SCORE=0.5

# ===========================================
# Alibaba Cloud AI Configuration
# ===========================================
ALIBABA_API_KEY=sk-sp-83766abe865e4c14af18ae9a918c7d8b
ALIBABA_AI_API_KEY=sk-sp-83766abe865e4c14af18ae9a918c7d8b

# ===========================================
# SMTP Configuration (Email Notifications)
# ===========================================
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ===========================================
# Analytics & Tracking
# ===========================================
NUXT_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NUXT_CLARITY_PROJECT_ID=your-clarity-project-id
NUXT_META_PIXEL_ID=your-meta-pixel-id
NUXT_TIKTOK_PIXEL_ID=your-tiktok-pixel-id
NUXT_LINKEDIN_PIXEL_ID=your-linkedin-pixel-id

# ===========================================
# CDN Configuration (Optional)
# ===========================================
CDN_PROVIDER=cloudflare
CDN_URL=https://your-cdn-url.com

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
RUST_LOG=debug