<svg width="1920" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="contactGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366F1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4F46E5;stop-opacity:1" />
    </linearGradient>
    <pattern id="contactPattern" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
      <line x1="25" y1="0" x2="25" y2="50" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
      <line x1="0" y1="25" x2="50" y2="25" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="400" fill="url(#contactGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="1920" height="400" fill="url(#contactPattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="250" cy="150" r="55" fill="rgba(255,255,255,0.05)"/>
  <circle cx="1650" cy="250" r="85" fill="rgba(255,255,255,0.05)"/>
  <rect x="850" y="140" width="220" height="120" fill="rgba(255,255,255,0.05)" rx="20"/>
  
  <!-- Text -->
  <text x="960" y="190" font-family="Arial, sans-serif" font-size="56" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">CONTACT</text>
  <text x="960" y="250" font-family="Arial, sans-serif" font-size="32" fill="rgba(255,255,255,0.8)" text-anchor="middle">Contact Banner</text>
  <text x="960" y="300" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.6)" text-anchor="middle">1920 × 400px</text>
</svg>
