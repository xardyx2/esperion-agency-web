<svg width="768" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="homeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2B9EDB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e7ab8;stop-opacity:1" />
    </linearGradient>
    <pattern id="homePattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
      <circle cx="30" cy="30" r="2" fill="rgba(255,255,255,0.1)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="768" height="400" fill="url(#homeGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="768" height="400" fill="url(#homePattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="100" cy="120" r="50" fill="rgba(255,255,255,0.05)"/>
  <circle cx="650" cy="280" r="70" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Text -->
  <text x="384" y="190" font-family="Arial, sans-serif" font-size="42" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">ESPERION</text>
  <text x="384" y="240" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.8)" text-anchor="middle">Homepage Banner</text>
  <text x="384" y="280" font-family="Arial, sans-serif" font-size="18" fill="rgba(255,255,255,0.6)" text-anchor="middle">768 × 400px</text>
</svg>
