<svg width="1920" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="worksGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6D28D9;stop-opacity:1" />
    </linearGradient>
    <pattern id="worksPattern" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
      <rect x="10" y="10" width="20" height="20" fill="rgba(255,255,255,0.08)"/>
      <rect x="50" y="50" width="20" height="20" fill="rgba(255,255,255,0.08)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="400" fill="url(#worksGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="1920" height="400" fill="url(#worksPattern)"/>
  
  <!-- Geometric shapes -->
  <rect x="200" cy="100" width="100" height="100" fill="rgba(255,255,255,0.05)" transform="rotate(30 250 150)"/>
  <rect x="1500" y="250" width="80" height="80" fill="rgba(255,255,255,0.05)" transform="rotate(15 1540 290)"/>
  <polygon points="1200,80 1250,160 1150,160" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Text -->
  <text x="960" y="190" font-family="Arial, sans-serif" font-size="56" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">PORTFOLIO</text>
  <text x="960" y="250" font-family="Arial, sans-serif" font-size="32" fill="rgba(255,255,255,0.8)" text-anchor="middle">Works Banner</text>
  <text x="960" y="300" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.6)" text-anchor="middle">1920 × 400px</text>
</svg>
