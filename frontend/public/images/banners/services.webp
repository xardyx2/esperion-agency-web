<svg width="1920" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="servicesGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10B981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
    <pattern id="servicesPattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="60" y2="60" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
      <line x1="60" y1="0" x2="0" y2="60" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="400" fill="url(#servicesGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="1920" height="400" fill="url(#servicesPattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="400" cy="200" r="60" fill="rgba(255,255,255,0.05)"/>
  <circle cx="1500" cy="200" r="100" fill="rgba(255,255,255,0.05)"/>
  <rect x="900" y="150" width="120" height="100" fill="rgba(255,255,255,0.05)" rx="10"/>
  
  <!-- Text -->
  <text x="960" y="190" font-family="Arial, sans-serif" font-size="56" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">SERVICES</text>
  <text x="960" y="250" font-family="Arial, sans-serif" font-size="32" fill="rgba(255,255,255,0.8)" text-anchor="middle">Services Banner</text>
  <text x="960" y="300" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.6)" text-anchor="middle">1920 × 400px</text>
</svg>
