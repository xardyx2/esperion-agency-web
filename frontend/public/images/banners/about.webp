<svg width="1920" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="aboutGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#14B8A6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0D9488;stop-opacity:1" />
    </linearGradient>
    <pattern id="aboutPattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
      <path d="M50 0 L100 50 L50 100 L0 50 Z" fill="rgba(255,255,255,0.06)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="400" fill="url(#aboutGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="1920" height="400" fill="url(#aboutPattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="350" cy="180" r="70" fill="rgba(255,255,255,0.05)"/>
  <circle cx="1550" cy="220" r="90" fill="rgba(255,255,255,0.05)"/>
  <polygon points="800,150 850,200 800,250 750,200" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Text -->
  <text x="960" y="190" font-family="Arial, sans-serif" font-size="56" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">ABOUT US</text>
  <text x="960" y="250" font-family="Arial, sans-serif" font-size="32" fill="rgba(255,255,255,0.8)" text-anchor="middle">About Banner</text>
  <text x="960" y="300" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.6)" text-anchor="middle">1920 × 400px</text>
</svg>
