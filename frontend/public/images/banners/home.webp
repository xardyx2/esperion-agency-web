<svg width="1920" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="homeGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2B9EDB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e7ab8;stop-opacity:1" />
    </linearGradient>
    <pattern id="homePattern" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
      <circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="0" cy="0" r="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="100" cy="100" r="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="100" cy="0" r="2" fill="rgba(255,255,255,0.1)"/>
      <circle cx="0" cy="100" r="2" fill="rgba(255,255,255,0.1)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="1920" height="600" fill="url(#homeGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="1920" height="600" fill="url(#homePattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="300" cy="150" r="80" fill="rgba(255,255,255,0.05)"/>
  <circle cx="1600" cy="450" r="120" fill="rgba(255,255,255,0.05)"/>
  <rect x="800" y="100" width="60" height="60" fill="rgba(255,255,255,0.05)" transform="rotate(45 830 130)"/>
  
  <!-- Text -->
  <text x="960" y="280" font-family="Arial, sans-serif" font-size="72" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">ESPERION</text>
  <text x="960" y="360" font-family="Arial, sans-serif" font-size="36" fill="rgba(255,255,255,0.8)" text-anchor="middle">Homepage Banner</text>
  <text x="960" y="420" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.6)" text-anchor="middle">1920 × 600px</text>
</svg>
