<svg width="768" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="aboutGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#14B8A6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0D9488;stop-opacity:1" />
    </linearGradient>
    <pattern id="aboutPattern" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M30 0 L60 30 L30 60 L0 30 Z" fill="rgba(255,255,255,0.06)"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="768" height="400" fill="url(#aboutGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="768" height="400" fill="url(#aboutPattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="130" cy="160" r="45" fill="rgba(255,255,255,0.05)"/>
  <circle cx="630" cy="240" r="55" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Text -->
  <text x="384" y="190" font-family="Arial, sans-serif" font-size="42" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">ABOUT US</text>
  <text x="384" y="240" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.8)" text-anchor="middle">About Banner</text>
  <text x="384" y="280" font-family="Arial, sans-serif" font-size="18" fill="rgba(255,255,255,0.6)" text-anchor="middle">768 × 400px</text>
</svg>
