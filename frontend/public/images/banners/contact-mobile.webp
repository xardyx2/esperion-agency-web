<svg width="768" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="contactGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366F1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4F46E5;stop-opacity:1" />
    </linearGradient>
    <pattern id="contactPattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <line x1="20" y1="0" x2="20" y2="40" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
      <line x1="0" y1="20" x2="40" y2="20" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Background -->
  <rect width="768" height="400" fill="url(#contactGradient)"/>
  
  <!-- Pattern overlay -->
  <rect width="768" height="400" fill="url(#contactPattern)"/>
  
  <!-- Geometric shapes -->
  <circle cx="90" cy="140" r="38" fill="rgba(255,255,255,0.05)"/>
  <circle cx="670" cy="260" r="52" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Text -->
  <text x="384" y="190" font-family="Arial, sans-serif" font-size="42" font-weight="bold" fill="rgba(255,255,255,0.9)" text-anchor="middle">CONTACT</text>
  <text x="384" y="240" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.8)" text-anchor="middle">Contact Banner</text>
  <text x="384" y="280" font-family="Arial, sans-serif" font-size="18" fill="rgba(255,255,255,0.6)" text-anchor="middle">768 × 400px</text>
</svg>
