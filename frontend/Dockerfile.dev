# Frontend Dockerfile - Nuxt 4 development with Bun
FROM oven/bun:1-alpine

# Install dependencies for sharp (libvips)
RUN apk add --no-cache \
    build-base \
    vips-dev \
    vips-heif \
    vips-magick \
    vips-poppler \
    python3 \
    pkgconfig

WORKDIR /app

# Install dependencies with Bun
COPY package.json bun.lockb* ./
RUN bun install --frozen-lockfile

# Copy source code
COPY . .

# Prepare Nuxt after source is present
RUN bun run postinstall || true

# Expose port
EXPOSE 3000

# Start development server with dependency sync for mounted volumes
CMD ["sh", "/app/docker-entrypoint.sh"]
