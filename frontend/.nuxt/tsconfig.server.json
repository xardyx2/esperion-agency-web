{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "~/*": [
        "../*"
      ],
      "@/*": [
        "../*"
      ],
      "~~/*": [
        "../*"
      ],
      "@@/*": [
        "../*"
      ],
      "@unhead/vue": [
        "../node_modules/@unhead/vue"
      ],
      "@nuxt/devtools": [
        "../node_modules/@nuxt/devtools"
      ],
      "@vue/runtime-core": [
        "../node_modules/@vue/runtime-core"
      ],
      "@vue/compiler-sfc": [
        "../node_modules/@vue/compiler-sfc"
      ],
      "@nuxt/schema": [
        "../node_modules/@nuxt/schema"
      ],
      "nuxt": [
        "../node_modules/nuxt"
      ],
      "vite/client": [
        "../node_modules/vite/client"
      ],
      "nuxt-site-config": [
        "../node_modules/nuxt-site-config"
      ],
      "vue-i18n": [
        "../node_modules/vue-i18n"
      ],
      "@intlify/shared": [
        "../node_modules/@intlify/shared"
      ],
      "@intlify/core": [
        "../node_modules/@intlify/core"
      ],
      "@intlify/core-base": [
        "../node_modules/@intlify/core-base"
      ],
      "@intlify/utils": [
        "../node_modules/@intlify/utils"
      ],
      "@intlify/utils/h3": [
        "../node_modules/@intlify/utils"
      ],
      "@intlify/message-compiler": [
        "../node_modules/@intlify/message-compiler"
      ],
      "nitropack/types": [
        "../node_modules/nitropack/types"
      ],
      "nitropack/runtime": [
        "../node_modules/nitropack/runtime"
      ],
      "nitropack": [
        "../node_modules/nitropack"
      ],
      "defu": [
        "../node_modules/defu"
      ],
      "h3": [
        "../node_modules/h3"
      ],
      "consola": [
        "../node_modules/consola"
      ],
      "ofetch": [
        "../node_modules/ofetch"
      ],
      "crossws": [
        "../node_modules/crossws"
      ],
      "#shared": [
        "../shared"
      ],
      "#shared/*": [
        "../shared/*"
      ],
      "#server": [
        "../server"
      ],
      "#server/*": [
        "../server/*"
      ],
      "#build": [
        "./"
      ],
      "#build/*": [
        "./*"
      ],
      "#internal/nuxt/paths": [
        "../node_modules/@nuxt/nitro-server/dist/runtime/utils/paths"
      ],
      "#ui": [
        "../node_modules/@nuxt/ui/dist/runtime"
      ],
      "#ui/*": [
        "../node_modules/@nuxt/ui/dist/runtime/*"
      ],
      "#sitemap": [
        "../node_modules/@nuxtjs/sitemap/dist/runtime"
      ],
      "#sitemap/*": [
        "../node_modules/@nuxtjs/sitemap/dist/runtime/*"
      ],
      "#site-config": [
        "../node_modules/nuxt-site-config/dist/runtime"
      ],
      "#site-config/*": [
        "../node_modules/nuxt-site-config/dist/runtime/*"
      ],
      "#robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime"
      ],
      "#robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/*"
      ],
      "#i18n": [
        "../node_modules/@nuxtjs/i18n/dist/runtime/composables/index-server"
      ],
      "#i18n-kit": [
        "../node_modules/@nuxtjs/i18n/dist/runtime/kit"
      ],
      "#i18n-kit/*": [
        "../node_modules/@nuxtjs/i18n/dist/runtime/kit/*"
      ],
      "#internal-i18n-types": [
        "../node_modules/@nuxtjs/i18n/dist/types"
      ],
      "vee-validate": [
        "../node_modules/vee-validate/dist/vee-validate"
      ],
      "@vee-validate/zod": [
        "../node_modules/@vee-validate/zod/dist/vee-validate-zod"
      ],
      "#unhead/composables": [
        "../node_modules/nuxt/dist/head/runtime/composables"
      ],
      "#nuxt-icon-server-bundle": [
        "./nuxt-icon-server-bundle"
      ],
      "#internal/nuxt-site-config": [
        "../node_modules/nuxt-site-config/dist/runtime/server/composable-barrel-deprecated"
      ],
      "#internal/nuxt-simple-robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables"
      ],
      "#internal/nuxt-simple-robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables/*"
      ],
      "#internal/nuxt-robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables"
      ],
      "#internal/nuxt-robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables/*"
      ]
    },
    "lib": [
      "esnext",
      "webworker",
      "dom.iterable"
    ],
    "noUncheckedIndexedAccess": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "../node_modules/@nuxtjs/mcp-toolkit/dist/runtime/server/types.server.d.ts",
    "./types/nitro-nuxt.d.ts",
    "../node_modules/runtime/server",
    "../node_modules/dist/runtime/server",
    "../node_modules/nuxt-site-config/dist/runtime/server",
    "../node_modules/nuxt-site-config/dist/dist/runtime/server",
    "../server/**/*",
    "../shared/**/*.d.ts",
    "./types/nitro.d.ts"
  ],
  "exclude": [
    "../node_modules",
    "../../node_modules",
    "../node_modules/nuxt/node_modules",
    "../node_modules/@nuxt/icon/node_modules",
    "../node_modules/@nuxt/ui/node_modules",
    "../node_modules/@nuxt/image/node_modules",
    "../node_modules/@nuxt/fonts/node_modules",
    "../node_modules/nuxt-site-config/node_modules",
    "../node_modules/@nuxtjs/sitemap/node_modules",
    "../node_modules/@nuxtjs/robots/node_modules",
    "../node_modules/@nuxt/eslint/node_modules",
    "../node_modules/@nuxtjs/color-mode/node_modules",
    "../node_modules/@nuxtjs/i18n/node_modules",
    "../node_modules/@pinia/nuxt/node_modules",
    "../node_modules/pinia-plugin-persistedstate/node_modules",
    "../node_modules/nuxt-csurf/node_modules",
    "../node_modules/nuxt-security/node_modules",
    "../node_modules/@vee-validate/nuxt/node_modules",
    "../node_modules/@scalar/nuxt/node_modules",
    "../node_modules/@nuxtjs/mcp-toolkit/node_modules",
    "../node_modules/@nuxt/devtools/node_modules",
    "../node_modules/@nuxt/telemetry/node_modules",
    "../dist"
  ]
}