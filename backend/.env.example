# Server Configuration
HOST=0.0.0.0
PORT=8080

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=8000
DB_USER=root
DB_PASS=root
DB_NS=esperion
DB_DB=esperion_db

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-make-it-long-and-secure
JWT_EXPIRATION_HOURS=24

# Argon2 Password Hashing Configuration
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Email Configuration
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@esperion.agency

# SMTP Configuration (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-app-password
SMTP_ENCRYPTION=starttls

# SendGrid Configuration (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun Configuration (used when EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.mailgun.org

# Amazon SES Configuration (used when EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
SES_REGION=us-east-1

# Postmark Configuration (used when EMAIL_PROVIDER=postmark)
POSTMARK_API_KEY=your-postmark-api-key

# SMTP2GO Configuration (used when EMAIL_PROVIDER=smtp2go) 
SMTP2GO_API_KEY=your-smtp2go-api-key

# Cloudflare IPs for Geo Location (Leave empty to use CF-Connecting-IP header)
CF_IP4_RANGES=""

CF_IP6_RANGES=""

# Google reCAPTCHA (Optional)
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# WebP Conversion Settings
WEBP_QUALITY=80
IMAGE_SIZES=thumbnail:150x150,small:300x300,medium:600x600,large:1200x1200
KEEP_ORIGINAL_IMAGES=true